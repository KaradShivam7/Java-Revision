package Condition_statement;

public class if_elseif_else {
	
	public static void main(String[] args) {
		
		int age=10;
		
		if(age>0 && age<=10) {
			System.out.println("child!!!");
		}
		else if(age>10 && age<18) {
			System.out.println("teenager!!!");
		}
		else {
			System.out.println("adult!!!");
		}
	}

}
